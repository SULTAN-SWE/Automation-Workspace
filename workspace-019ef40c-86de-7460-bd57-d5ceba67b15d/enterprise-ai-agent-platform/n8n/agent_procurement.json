      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "4c9461f2-4e02-4021-abfc-dfc7ddc8b56d",
              "name": "status",
              "value": "pending_approval",
              "type": "string"
            },
            {
              "id": "69b2b076-e09f-4912-b890-777b1ecde645",
              "name": "response",
              "value": "={{ `Your request has been submitted for manager approval. You will be notified once it is reviewed.` }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "589df697-53bd-483e-b1ba-f6b5391e41c2",
      "name": "Respond Pending",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
