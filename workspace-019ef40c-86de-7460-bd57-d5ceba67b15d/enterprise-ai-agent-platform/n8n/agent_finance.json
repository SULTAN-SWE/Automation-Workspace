        "jsonBody": "={{ $json.body }}"
      }
    },
    {
      "id": "7cf99f8e-8da8-4a2d-8a2b-d8951e2dca7e",
      "name": "Format Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2100,
        300
      ],
      "parameters": {
        "jsCode": "\nconst input = $input.first().json;\nconst ctx = input.metadata || {};\nreturn [{ json: { request_id: ctx.request_id, agent: input.agent || 'HR', status: input.status || 'success', result: input.result || input, message: input.message || 'Completed' } }];\n"
      }
    },
    {
      "id": "b64bd3f9-d92d-42b0-bc7f-4c0cdd15ff89",
      "name": "Respond Result",
      "type": "n8n-nodes-base.respondToWebhook",
