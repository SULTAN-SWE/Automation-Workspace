      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "40406ca7-fb72-4a84-8293-4b1c5c287d4e",
              "name": "status",
              "value": "pending_approval",
              "type": "string"
            },
            {
              "id": "ec81da34-69d0-4c86-858a-1418fd02ef03",
              "name": "response",
              "value": "={{ `Your request has been submitted for manager approval. You will be notified once it is reviewed.` }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "3642c9e3-4e38-49ed-acce-14e71092efda",
      "name": "Respond Pending",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
