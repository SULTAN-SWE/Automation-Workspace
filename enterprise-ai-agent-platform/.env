# Backend FastAPI
DATABASE_URL=sqlite:///./enterprise_ai.db
# For Microsoft SQL Server (production):
# DATABASE_URL=mssql+pyodbc://sa:YourStrong@Passw0rd@localhost:1433/EnterpriseAIPlatform?driver=ODBC+Driver+17+for+SQL+Server
JWT_SECRET=change-me-jwt-secret
JWT_EXPIRATION_MINUTES=60

# Backend URL used by n8n to call the FastAPI business logic
BACKEND_API_URL=http://host.docker.internal:8000

# n8n Webhook URL used by the backend and between workflows
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# Shared API key between FastAPI and n8n Master Orchestrator
ORCHESTRATOR_API_KEY=change-me-api-key

# Key used by the approval webhook (manager approval links)
MANAGER_API_KEY=manager-secret

# OpenAI (configured in n8n UI credentials as well)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxx
